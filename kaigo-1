let deck = [...VOCAB];
let currentIdx = 0;
let flipped = false;
let mode = 'jp'; // 'jp' or 'id'
let marks = {}; // id -> 'know' | 'learn'
let selectedCat = 'all';
let listOpen = false;

// Build category pills
function buildCats() {
  const section = document.getElementById('catSection');
  const cats = ['all', 'body', 'food', 'eating', 'move', 'illness', 'posture'];
  const labels = { all:'すべて', ...CAT_NAMES };
  cats.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'cat-pill' + (cat === 'all' ? ' active' : '');
    btn.textContent = labels[cat];
    if (cat !== 'all') {
      btn.style.setProperty('--cc', CAT_COLORS[cat]);
      btn.style.background = cat === selectedCat ? CAT_COLORS[cat] : '';
    }
    btn.onclick = () => {
      document.querySelectorAll('.cat-pill').forEach(b => {
        b.classList.remove('active');
        b.style.background = '';
        b.style.color = '';
      });
      btn.classList.add('active');
      if (cat !== 'all') { btn.style.background = CAT_COLORS[cat]; btn.style.color = '#0f0e17'; }
      selectedCat = cat;
      filterAndReset();
    };
    section.appendChild(btn);
  });
}

function filterAndReset() {
  deck = selectedCat === 'all' ? [...VOCAB] : VOCAB.filter(v => v.cat === selectedCat);
  currentIdx = 0;
  flipped = false;
  document.getElementById('cardInner').classList.remove('flipped');
  renderCard();
  buildList();
}

function setMode(m, btn) {
  mode = m;
  document.querySelectorAll('.mode-pill').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  flipped = false;
  document.getElementById('cardInner').classList.remove('flipped');
  renderCard();
}

function renderCard() {
  const endScreen = document.getElementById('endScreen');
  const cardArea = document.getElementById('cardArea');
  const markRow = document.getElementById('markRow');

  if (deck.length === 0) return;
  if (currentIdx >= deck.length) {
    endScreen.classList.add('show');
    cardArea.style.display = 'none';
    markRow.style.display = 'none';
    const know = Object.values(marks).filter(v=>v==='know').length;
    const learn = Object.values(marks).filter(v=>v==='learn').length;
    document.getElementById('endSub').textContent = `✅ わかった: ${know}  📚 もっとべんきょう: ${learn}`;
    return;
  }

  endScreen.classList.remove('show');
  cardArea.style.display = '';
  markRow.style.display = '';

  const v = deck[currentIdx];
  const color = CAT_COLORS[v.cat] || '#ffd93d';

  // Accent colors
  document.getElementById('cardFront').style.setProperty('--c-accent', color);
  document.getElementById('cardBack').style.setProperty('--c-accent', color);

  document.getElementById('cfCat').textContent = CAT_NAMES[v.cat] || v.cat;
  document.getElementById('cbCat').textContent = CAT_NAMES[v.cat] || v.cat;

  if (mode === 'jp') {
    // Front: Japanese kanji+furigana
    const isSame = v.kanji === v.romaji;
    document.getElementById('cfKanji').innerHTML = isSame
      ? `<ruby>${v.kanji}<rt></rt></ruby>`
      : `<ruby>${v.kanji}<rt>${v.romaji}</rt></ruby>`;
    // Back: Indonesian
    document.getElementById('cbIndo').textContent = v.id_;
    document.getElementById('cbRomaji').textContent = v.romaji;
    document.getElementById('cbAlso').textContent = '↑ bacaan · 読み方';
  } else {
    // Front: Indonesian
    document.getElementById('cfKanji').innerHTML = `<span style="font-family:'M PLUS Rounded 1c';font-size:clamp(1.4rem,5vw,2.2rem)">${v.id_}</span>`;
    // Back: Japanese
    const isSame = v.kanji === v.romaji;
    document.getElementById('cbIndo').innerHTML = isSame
      ? `<ruby>${v.kanji}<rt></rt></ruby>`
      : `<ruby>${v.kanji}<rt>${v.romaji}</rt></ruby>`;
    document.getElementById('cbIndo').style.fontFamily = "'Kaisei Decol', serif";
    document.getElementById('cbIndo').style.fontSize = 'clamp(2rem, 8vw, 3rem)';
    document.getElementById('cbRomaji').textContent = v.romaji;
    document.getElementById('cbAlso').textContent = '';
  }

  // Stats
  document.getElementById('cCounter').textContent = currentIdx + 1;
  document.getElementById('cTotal').textContent = deck.length;
  const knowCount = deck.filter(v => marks[v.id] === 'know').length;
  const learnCount = deck.filter(v => marks[v.id] === 'learn').length;
  document.getElementById('cKnow').textContent = knowCount;
  document.getElementById('cLearn').textContent = learnCount;
  document.getElementById('progFill').style.width = `${(currentIdx / deck.length) * 100}%`;

  // Prev button
  document.getElementById('prevBtn').disabled = currentIdx === 0;
}

function flipCard() {
  flipped = !flipped;
  document.getElementById('cardInner').classList.toggle('flipped', flipped);
}

function nextCard() {
  flipped = false;
  document.getElementById('cardInner').classList.remove('flipped');
  currentIdx++;
  renderCard();
}

function prevCard() {
  if (currentIdx === 0) return;
  flipped = false;
  document.getElementById('cardInner').classList.remove('flipped');
  currentIdx--;
  renderCard();
}

function markCard(type) {
  const v = deck[currentIdx];
  marks[v.id] = type;
  nextCard();
}

function shuffleCards() {
  for (let i = deck.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [deck[i], deck[j]] = [deck[j], deck[i]];
  }
  currentIdx = 0;
  flipped = false;
  document.getElementById('cardInner').classList.remove('flipped');
  document.getElementById('endScreen').classList.remove('show');
  document.getElementById('cardArea').style.display = '';
  document.getElementById('markRow').style.display = '';
  renderCard();
}

function resetDeck() {
  marks = {};
  currentIdx = 0;
  flipped = false;
  document.getElementById('cardInner').classList.remove('flipped');
  document.getElementById('endScreen').classList.remove('show');
  document.getElementById('cardArea').style.display = '';
  document.getElementById('markRow').style.display = '';
  deck = selectedCat === 'all' ? [...VOCAB] : VOCAB.filter(v => v.cat === selectedCat);
  renderCard();
  buildList();
}

function toggleList(btn) {
  listOpen = !listOpen;
  const list = document.getElementById('vocabList');
  list.classList.toggle('open', listOpen);
  document.getElementById('listArrow').textContent = listOpen ? '▲' : '▼';
}

function buildList() {
  const list = document.getElementById('vocabList');
  list.innerHTML = '';
  const pool = selectedCat === 'all' ? VOCAB : VOCAB.filter(v => v.cat === selectedCat);
  pool.forEach(v => {
    const row = document.createElement('div');
    const markClass = marks[v.id] === 'know' ? 'known' : marks[v.id] === 'learn' ? 'learning' : '';
    row.className = `vocab-row ${markClass}`;
    row.style.borderLeftColor = CAT_COLORS[v.cat];
    row.innerHTML = `
      <div>
        <div class="vr-kanji">${v.kanji}</div>
        <div class="vr-romaji">${v.romaji}</div>
      </div>
      <div class="vr-indo">${v.id_}</div>
    `;
    row.onclick = () => {
      const idx = deck.findIndex(d => d.id === v.id);
      if (idx !== -1) {
        currentIdx = idx;
        flipped = false;
        document.getElementById('cardInner').classList.remove('flipped');
        document.getElementById('endScreen').classList.remove('show');
        document.getElementById('cardArea').style.display = '';
        document.getElementById('markRow').style.display = '';
        renderCard();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    };
    list.appendChild(row);
  });
}

// Keyboard support
document.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); flipped ? nextCard() : flipCard(); }
  if (e.key === 'ArrowLeft') prevCard();
  if (e.key === 'ArrowUp') markCard('know');
  if (e.key === 'ArrowDown') markCard('learn');
});

// Init
buildCats();
buildList();
renderCard();
</script>
