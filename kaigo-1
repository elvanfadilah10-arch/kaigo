<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flashcard 介護語彙</title>
<link href="https://fonts.googleapis.com/css2?family=Kaisei+Decol:wght@400;700&family=M+PLUS+Rounded+1c:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0e17;
    --surface: #1a1828;
    --card-front: #1e1b2e;
    --card-back: #12253a;
    --accent1: #ff6b6b;
    --accent2: #ffd93d;
    --accent3: #6bcb77;
    --accent4: #4d96ff;
    --accent5: #c77dff;
    --accent6: #a8e6cf;
    --text: #f5f0e8;
    --muted: #9a8f78;
    --border: rgba(255,255,255,0.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'M PLUS Rounded 1c', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* NOISE OVERLAY */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  /* HEADER */
  header {
    position: relative;
    z-index: 1;
    padding: 28px 20px 20px;
    text-align: center;
    border-bottom: 1px solid var(--border);
  }
  .title {
    font-family: 'Kaisei Decol', serif;
    font-size: clamp(1.4rem, 5vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    background: linear-gradient(135deg, #ffd93d, #ff6b6b, #c77dff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .subtitle {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* CATEGORY FILTER */
  .cat-section {
    position: relative; z-index: 1;
    padding: 16px 14px 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    justify-content: center;
  }
  .cat-pill {
    padding: 5px 14px;
    border-radius: 30px;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    border: 1.5px solid transparent;
    background: var(--surface);
    color: var(--muted);
    transition: all 0.2s;
    letter-spacing: 0.04em;
  }
  .cat-pill:hover { color: var(--text); }
  .cat-pill.active {
    color: var(--bg);
    border-color: transparent;
  }

  /* STATS BAR */
  .stats-bar {
    position: relative; z-index: 1;
    display: flex;
    gap: 14px;
    justify-content: center;
    align-items: center;
    padding: 10px 14px;
    flex-wrap: wrap;
  }
  .stat-chip {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.05em;
  }
  .stat-chip span {
    color: var(--text);
    font-size: 1rem;
  }

  /* PROGRESS BAR */
  .prog-wrap {
    position: relative; z-index: 1;
    padding: 0 20px 8px;
  }
  .prog-bg {
    height: 3px;
    background: var(--border);
    border-radius: 3px;
    overflow: hidden;
  }
  .prog-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--accent4), var(--accent5));
    transition: width 0.4s ease;
  }

  /* MAIN CARD AREA */
  .card-area {
    position: relative; z-index: 1;
    padding: 20px 16px 10px;
    perspective: 1200px;
    display: flex;
    justify-content: center;
  }

  .card-scene {
    width: 100%;
    max-width: 420px;
    height: 240px;
    cursor: pointer;
  }

  .card-inner {
    width: 100%; height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.34, 1.1, 0.64, 1);
  }
  .card-inner.flipped { transform: rotateY(180deg); }

  .card-face {
    position: absolute; inset: 0;
    border-radius: 20px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 20px;
    border: 1px solid var(--border);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  .card-front {
    background: var(--card-front);
  }
  .card-back {
    background: var(--card-back);
    transform: rotateY(180deg);
  }

  /* Accent line top */
  .card-face::before {
    content: '';
    position: absolute;
    top: 0; left: 20px; right: 20px;
    height: 3px;
    border-radius: 0 0 3px 3px;
    background: var(--c-accent, #ffd93d);
  }

  .card-cat {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-accent, #ffd93d);
    margin-bottom: 14px;
  }

  .card-kanji {
    font-family: 'Kaisei Decol', serif;
    font-size: clamp(2.4rem, 9vw, 3.4rem);
    font-weight: 700;
    line-height: 1.15;
    text-align: center;
    letter-spacing: 0.05em;
    color: var(--text);
  }
  .card-kanji ruby rt {
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-size: 0.35em;
    color: var(--muted);
    font-weight: 400;
  }

  .card-hint {
    font-size: 0.7rem;
    color: var(--muted);
    margin-top: 14px;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .flip-icon {
    width: 14px; height: 14px;
    opacity: 0.5;
  }

  .card-indo {
    font-size: clamp(1.3rem, 5vw, 1.9rem);
    font-weight: 800;
    text-align: center;
    color: var(--text);
    line-height: 1.4;
  }
  .card-romaji {
    font-size: 0.9rem;
    color: var(--muted);
    margin-top: 10px;
    letter-spacing: 0.05em;
  }
  .card-also {
    font-size: 0.65rem;
    color: var(--muted);
    margin-top: 18px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* CONTROLS */
  .controls {
    position: relative; z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 14px;
    padding: 16px 14px;
    flex-wrap: wrap;
  }

  .ctrl-btn {
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 50px;
    padding: 10px 22px;
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .ctrl-btn:hover {
    background: rgba(255,255,255,0.08);
    transform: translateY(-1px);
  }
  .ctrl-btn:active { transform: translateY(1px); }
  .ctrl-btn.primary {
    background: var(--accent4);
    border-color: var(--accent4);
    color: #fff;
    padding: 11px 28px;
    font-size: 0.88rem;
  }
  .ctrl-btn.primary:hover { background: #6aaeff; }
  .ctrl-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  /* MARK BUTTONS */
  .mark-row {
    position: relative; z-index: 1;
    display: flex;
    gap: 10px;
    justify-content: center;
    padding: 0 14px 10px;
  }
  .mark-btn {
    flex: 1;
    max-width: 180px;
    padding: 10px 16px;
    border-radius: 12px;
    border: 1px solid;
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.03em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .mark-know {
    background: rgba(107, 203, 119, 0.12);
    border-color: rgba(107, 203, 119, 0.4);
    color: var(--accent3);
  }
  .mark-know:hover { background: rgba(107, 203, 119, 0.22); }
  .mark-learn {
    background: rgba(255, 107, 107, 0.12);
    border-color: rgba(255, 107, 107, 0.4);
    color: var(--accent1);
  }
  .mark-learn:hover { background: rgba(255, 107, 107, 0.22); }

  /* VOCAB LIST */
  .list-section {
    position: relative; z-index: 1;
    padding: 10px 14px 16px;
  }
  .list-toggle {
    width: 100%;
    background: none;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--muted);
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 10px 16px;
    cursor: pointer;
    text-align: left;
    letter-spacing: 0.05em;
    transition: all 0.2s;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .list-toggle:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

  .vocab-list {
    display: none;
    margin-top: 10px;
    display: none;
    gap: 6px;
    flex-direction: column;
  }
  .vocab-list.open { display: flex; }

  .vocab-row {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .vocab-row:hover { border-color: rgba(255,255,255,0.15); }
  .vocab-row.known { border-left: 3px solid var(--accent3); }
  .vocab-row.learning { border-left: 3px solid var(--accent1); }

  .vr-kanji {
    font-family: 'Kaisei Decol', serif;
    font-size: 1.1rem;
    font-weight: 700;
    min-width: 50px;
    color: var(--text);
  }
  .vr-romaji { font-size: 0.7rem; color: var(--muted); }
  .vr-indo { font-size: 0.82rem; font-weight: 700; color: var(--muted); margin-left: auto; text-align: right; }

  /* MODE INDICATOR */
  .mode-row {
    position: relative; z-index: 1;
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 4px 14px 8px;
  }
  .mode-pill {
    padding: 4px 14px;
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    background: var(--surface);
    color: var(--muted);
    border: 1px solid var(--border);
    transition: all 0.2s;
    letter-spacing: 0.04em;
  }
  .mode-pill.active {
    background: var(--accent4);
    color: white;
    border-color: var(--accent4);
  }

  /* SHUFFLE indicator */
  .end-screen {
    display: none;
    position: relative; z-index: 1;
    text-align: center;
    padding: 40px 20px;
  }
  .end-screen.show { display: block; }
  .end-emoji { font-size: 3rem; margin-bottom: 12px; }
  .end-title {
    font-family: 'Kaisei Decol', serif;
    font-size: 1.5rem;
    background: linear-gradient(135deg, #ffd93d, #ff6b6b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .end-sub { font-size: 0.82rem; color: var(--muted); margin-top: 8px; }
  .end-btn {
    margin-top: 20px;
    background: var(--accent4);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 12px 32px;
    font-family: 'M PLUS Rounded 1c', sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: all 0.2s;
  }
  .end-btn:hover { background: #6aaeff; transform: translateY(-2px); }

  /* Swipe hint animation */
  @keyframes slideIn {
    from { opacity:0; transform: translateY(18px); }
    to { opacity:1; transform: translateY(0); }
  }
  .card-area { animation: slideIn 0.35s ease; }
</style>
</head>
<body>

<header>
  <div class="title">介護語彙 フラッシュカード</div>
  <div class="subtitle">Flashcard Kosakata Perawatan Lansia</div>
</header>

<div class="cat-section" id="catSection"></div>

<div class="mode-row">
  <button class="mode-pill active" onclick="setMode('jp',this)">日本語 → Indonesia</button>
  <button class="mode-pill" onclick="setMode('id',this)">Indonesia → 日本語</button>
</div>

<div class="stats-bar">
  <div class="stat-chip">カード <span id="cCounter">1</span>/<span id="cTotal">0</span></div>
  <div class="stat-chip">✅ <span id="cKnow">0</span></div>
  <div class="stat-chip">📚 <span id="cLearn">0</span></div>
</div>

<div class="prog-wrap">
  <div class="prog-bg"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
</div>

<div class="card-area" id="cardArea">
  <div class="card-scene" id="cardScene" onclick="flipCard()">
    <div class="card-inner" id="cardInner">
      <div class="card-face card-front" id="cardFront">
        <div class="card-cat" id="cfCat">からだ</div>
        <div class="card-kanji" id="cfKanji"></div>
        <div class="card-hint">
          <svg class="flip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
          タップしてめくる
        </div>
      </div>
      <div class="card-face card-back" id="cardBack">
        <div class="card-cat" id="cbCat">からだ</div>
        <div class="card-indo" id="cbIndo"></div>
        <div class="card-romaji" id="cbRomaji"></div>
        <div class="card-also" id="cbAlso"></div>
      </div>
    </div>
  </div>
</div>

<div class="mark-row" id="markRow">
  <button class="mark-btn mark-know" onclick="markCard('know')">✅ わかった</button>
  <button class="mark-btn mark-learn" onclick="markCard('learn')">📚 もっとべんきょう</button>
</div>

<div class="controls">
  <button class="ctrl-btn" id="prevBtn" onclick="prevCard()">← まえ</button>
  <button class="ctrl-btn primary" id="nextBtn" onclick="nextCard()">つぎ →</button>
  <button class="ctrl-btn" onclick="shuffleCards()">🔀 シャッフル</button>
</div>

<div class="end-screen" id="endScreen">
  <div class="end-emoji">🎉</div>
  <div class="end-title">おわりました！</div>
  <div class="end-sub" id="endSub"></div>
  <button class="end-btn" onclick="resetDeck()">🔄 もういちど</button>
</div>

<div class="list-section">
  <button class="list-toggle" onclick="toggleList(this)">
    <span>📋 すべてのことば一覧</span>
    <span id="listArrow">▼</span>
  </button>
  <div class="vocab-list" id="vocabList"></div>
</div>

